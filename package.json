{
  "name": "mealplanner",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run build:web",
    "build:web": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "check": "bun run --cwd apps/web check",
    "pages:preview": "bun run --cwd apps/web pages:preview",
    "pages:deploy": "bun run --cwd apps/web pages:deploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
